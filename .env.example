# TCG Tracker Backend - Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3001

# How often to scrape (cron format) - default: every 2 hours
SCRAPE_CRON="0 */2 * * *"

# Optional: Your zip code for "near me" checks (stores use this for local stock)
DEFAULT_ZIP_CODE=90210

# Optional: Push notification service (e.g. Expo push tokens stored in DB)
# EXPO_ACCESS_TOKEN=your_expo_token_here
